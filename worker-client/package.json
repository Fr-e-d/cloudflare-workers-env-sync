{
  "name": "microservice-client",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": " wrangler dev",
    "apply-secrets": "npm install && node src/configs/setSecrets.js",
    "apply-secrets:dev": "npm install && node src/configs/setSecrets.js --env development",
