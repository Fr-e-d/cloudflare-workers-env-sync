    "apply-secrets:prod": "npm install && node src/configs/setSecrets.js --env production"
  },
  "devDependencies": {
    "wrangler": "^4.15.1"
  },
  "type": "module",
  "dependencies": {
    "prompt-sync": "^4.2.0"
  }
}
